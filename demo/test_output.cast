[15.950078, "o", "                                                                                               \u001b[38;5;58m \u001b[0m\r\n\u001b[38;5;58m \u001b[0m                                                                                                                                                                                                      \u001b[38;5;58m \u001b[0m\r\n\u001b[38;5;58m \u001b[0m  \u001b[48;5;235m                                                                                                                                                                                                  \u001b[0m  \u001b[38;5;58m \u001b[0m\r\n\u001b[38;5;58m \u001b[0m  \u001b[48;5;235m \u001b[0m\u001b[38;5;231;48;5;235mFramework        Avg Response   P95 Latency\u001b[0m\u001b[48;5;235m                                                                                                                                                     \u001b[0m\u001b[48;5;235m \u001b[0m  \u001b[38;5;58m \u001b[0m\r\n\u001b[38;5;58m \u001b[0m  \u001b[48;5;235m \u001b[0m\u001b[38;5;231;48;5;235m────────────────────────────"]
[15.950146, "o", "─────────────────\u001b[0m\u001b[48;5;235m                                                                                                                                                   \u001b[0m\u001b[48;5;235m \u001b[0m  \u001b[38;5;58m \u001b[0m\r\n\u001b[38;5;58m \u001b[0m  \u001b[48;5;235m \u001b[0m\u001b[38;5;231;48;5;235mHermes Agent     0.82s          1.24s\u001b[0m\u001b[48;5;235m                                                                                                                                                           \u001b[0m\u001b[48;5;235m \u001b[0m  \u001b[38;5;58m \u001b[0m\r\n\u001b[38;5;58m \u001b[0m  \u001b[48;5;235m \u001b[0m\u001b[38;5;231;48;5;235mCrewAI           1.45s          2.31s\u001b[0m\u001b[48;5;235m                                                                                                                                                           \u001b[0m\u001b[48;5;235m \u001b[0m  \u001b[38;5;58m \u001b[0m\r\n\u001b[38;5;58m \u001b[0m  \u001b[48;5;235m \u001b[0m\u001b[38;5;231;48;5;235mAutoGen          1.12s          1.89s\u001b[0m\u001b[48;5;235m                                                                      "]
[15.950202, "o", "                                                                                     \u001b[0m\u001b[48;5;235m \u001b[0m  \u001b[38;5;58m \u001b[0m\r\n\u001b[38;5;58m \u001b[0m  \u001b[48;5;235m                                                                                                                                                                                                  \u001b[0m  \u001b[38;5;58m \u001b[0m\r\n\u001b[38;5;58m \u001b[0m                                                                                                                                                                                                      \u001b[38;5;58m \u001b[0m\r\n\u001b[38;5;58m \u001b[0m  Hermes Agent is the fastest for single-turn tool-use tasks, thanks to its optimized tool dispatch pipeline.                                                                                         \u001b[38;5;58m \u001b[0m\r\n\u001b[38;5;58m \u001b[0m                                                                                                                                                                                    "]
