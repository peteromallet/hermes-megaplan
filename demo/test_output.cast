[9.293034, "o", "────────────────────────────────────── \u001b[0m                                                                                                                        \u001b[38;5;58m \u001b[0m\r\n\u001b[38;5;58m \u001b[0m  \u001b[36m \u001b[0m\u001b[1mHermes Agent\u001b[0m \u001b[36m \u001b[0m12.4k \u001b[36m \u001b[0mFull-stack agent with browser, terminal, and tool use\u001b[36m \u001b[0m                                                                                                                        \u001b[38;5;58m \u001b[0m\r\n\u001b[38;5;58m \u001b[0m  \u001b[36m \u001b[0m\u001b[1mCrewAI\u001b[0m       \u001b[36m \u001b[0m28.1k \u001b[36m \u001b[0mMulti-agent orchestration with role-based agents     \u001b[36m \u001b[0m                                                                                                                        \u001b[38;5;58m \u001b[0m\r\n\u001b[38;5;58m \u001b[0m  \u001b[36m \u001b[0m\u001b[1mAutoGen\u001b[0m      \u001b[36m \u001b[0m35.2k \u001b[36m \u001b[0mMicrosoft's conversational agent framework           \u001b[36m \u001b[0m                                                                                    "]
