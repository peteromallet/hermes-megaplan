{
  "target_strict_score": 95,
  "review_max_age_days": 30,
  "review_batch_max_files": 80,
  "holistic_max_age_days": 30,
  "generate_scorecard": true,
  "badge_path": "scorecard.png",
  "exclude": [
    ".git",
    "__pycache__",
    ".pytest_cache",
    ".ruff_cache",
    "logs",
    "temp_vision_images",
    "website",
    "landingpage",
    "docs",
    "assets",
    "venv/",
    "venv",
    "demo/*"
  ],
  "ignore": [
    "test_coverage::hermes_cli/pairing.py::transitive_only",
    "test_coverage::hermes_constants.py::transitive_only",
    "test_coverage::tools/async_utils.py::transitive_only",
    "subjective_assessment",
    "workflow::",
    "smells::",
    "dict_keys::",
    "test_coverage::",
    "structural::",
    "security::",
    "orphaned::",
    "unused::",
    "props::"
  ],
  "ignore_metadata": {},
  "zone_overrides": {},
  "review_dimensions": [],
  "large_files_threshold": 0,
  "props_threshold": 0,
  "issue_noise_budget": 10,
  "issue_noise_global_budget": 0,
  "execution_log_max_entries": 10000,
  "needs_rescan": true,
  "languages": {},
  "commit_tracking_enabled": true,
  "commit_pr": 0,
  "commit_default_branch": "",
  "commit_message_template": "desloppify: {status} {count} issue(s) \u2014 {summary}",
  "trust_plugins": false,
  "transition_messages": {},
  "hermes_enabled": true,
  "hermes_models": {
    "execute": "openrouter:x-ai/grok-4.20-beta",
    "review": "openrouter:google/gemini-3.1-pro-preview"
  }
}
